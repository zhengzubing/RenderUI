{
  "window": {
    "title": "RenderUI Complete Demo",
    "width": 800,
    "height": 600
  },
  "widgets": [
    {
      "type": "Container",
      "id": "rootContainer",
      "x": 0,
      "y": 0,
      "width": 800,
      "height": 600,
      "children": [
        {
          "type": "ImageView",
          "id": "backgroundImage",
          "imagePath": "avatar.png",
          "x": 0,
          "y": 0,
          "width": 800,
          "height": 600,
          "scaleMode": "Fill"
        },
        {
          "type": "Label",
          "id": "titleLabel",
          "text": "欢迎使用 RenderUI",
          "x": 350,
          "y": 30,
          "width": 100,
          "height": 50
        },
        {
          "type": "Container",
          "id": "contentPanel",
          "x": 50,
          "y": 100,
          "width": 700,
          "height": 400,
          "children": [
            {
              "type": "ImageView",
              "id": "logoImage",
              "imagePath": "logo.png",
              "x": 5,
              "y": 535,
              "width": 50,
              "height": 50,
              "scaleMode": "Fill"
            },
            {
              "type": "Label",
              "id": "subtitleLabel",
              "text": "高性能 UI 框架",
              "x": 350,
              "y": 0,
              "width": 300,
              "height": 40
            },
            {
              "type": "Button",
              "id": "startButton",
              "text": "开始体验",
              "x": 300,
              "y": 500,
              "width": 200,
              "height": 60
            }
          ]
        },
        {
          "type": "Label",
          "id": "footerLabel",
          "text": "© 2024 RenderUI Framework",
          "x": 50,
          "y": 550,
          "width": 700,
          "height": 30
        }
      ]
    }
  ]
}
