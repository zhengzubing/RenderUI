{
    "name": "RenderUI Development",
    "dockerComposeFile": "docker-compose.yml",
    "service": "renderui-dev",
    "workspaceFolder": "/workspace/RenderUI",
    
    // 设置工作目录
    "shutdownAction": "none",
    
    // 安装 VS Code 扩展
    "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "twxs.cmake",
        "ms-python.python",
        "llvm-vs-code-extensions.vscode-clangd"
    ],
    
    // 容器创建后的命令
    "postCreateCommand": "echo 'RenderUI 开发环境已就绪！'",
    
    // 转发端口（如果需要）
    "forwardPorts": [],
    
    // 环境变量
    "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "C_Cpp.default.compilerPath": "/usr/bin/g++",
        "cmake.configureOnOpen": false
    }
}
